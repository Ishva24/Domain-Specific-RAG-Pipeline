# =============================================================================
# DocuQuery RAG — Environment Configuration Template
# Copy this file to .env and fill in the values
# =============================================================================

# --- LLM Provider ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone (Production Vector DB) ---
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=docuquery-prod

# --- MLflow Tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=docuquery-rag-v1

# --- Application Settings ---
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Retrieval Configuration ---
VECTOR_STORE_BACKEND=faiss    # faiss | pinecone
FAISS_INDEX_PATH=./data/faiss_index
CHUNK_STRATEGY=late_chunking  # late_chunking | parent_child | recursive
PARENT_CHUNK_SIZE=2000
CHILD_CHUNK_SIZE=400
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-en
EMBEDDING_MAX_SEQ_LEN=8192

# --- Hybrid Retrieval Weights ---
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7
INITIAL_RETRIEVAL_K=40
FINAL_RERANK_K=5

# --- Re-ranking ---
RERANKER_BACKEND=flashrank     # flashrank | bge | cohere
COHERE_API_KEY=                # only needed if using cohere reranker

# --- Streaming ---
STREAM_TIMEOUT_SECONDS=60
MAX_CONTEXT_TOKENS=4096

# --- Security ---
API_SECRET_KEY=change-me-in-production
